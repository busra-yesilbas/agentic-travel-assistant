# =============================================================================
# TripGenie Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The application runs fully in mock mode without any API keys.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
TRIPGENIE_ENV=development
TRIPGENIE_DEBUG=false
TRIPGENIE_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# LLM Provider
# Set LLM_PROVIDER=mock to run without any API key (default).
# Set LLM_PROVIDER=openai to use the OpenAI API.
# Set LLM_PROVIDER=openai_compatible for any OpenAI-compatible endpoint.
# ---------------------------------------------------------------------------
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=30

# Required only when LLM_PROVIDER != mock
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ---------------------------------------------------------------------------
# CORS (comma-separated origins)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
ENABLE_EVAL_ENDPOINT=true
ENABLE_METRICS=true
